# =============================================================================
# SafeO — copy to .env for local dev or docker compose (never commit .env)
#   cp .env.example .env
# =============================================================================

# --- API auth (Universal /v1/* routes) ---
SAFEO_API_KEYS=internal,your-demo-key

# --- SQLite feedback / Bayesian thresholds ---
# Local dev (run from backend/): data/safeo_feedback.db. Docker compose uses /data/...
SAFEO_FEEDBACK_DB=data/safeo_feedback.db

# --- Tier 3: local vLLM (disabled in Docker by default; no bundled vLLM server) ---
SECUREC_ENABLE_LLM_AUGMENTATION=false
SAFEO_LLM_SERVER_URL=http://localhost:8000/v1
SAFEO_LLM_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.2

# --- Agent orchestration (Fireworks on AMD infrastructure) ---
SAFEO_ENABLE_AGENT_LLM=false
SAFEO_AGENT_LLM_SERVER_URL=https://api.fireworks.ai/inference/v1
SAFEO_AGENT_LLM_API_KEY=your-fireworks-api-key
SAFEO_POLICY_AGENT_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct
SAFEO_FORENSICS_AGENT_MODEL=accounts/fireworks/models/deepseek-r1
SAFEO_REMEDIATION_AGENT_MODEL=accounts/fireworks/models/llama-v3p1-8b-instruct
SAFEO_VERIFIER_AGENT_MODEL=accounts/fireworks/models/llama-v3p1-8b-instruct

# --- Fireworks API (used by agent LLM + optional Bayesian reasoning) ---
FIREWORKS_API_KEY=your-fireworks-api-key
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# Set to "true" to mock Gemma responses without API credits during development
FIREWORKS_DRY_RUN=false

# --- Bayesian threshold adaptation (deterministic math; optional Fireworks reasoning) ---
SAFEO_ENABLE_BAYESIAN_LLM=false
SAFEO_BAYESIAN_LLM_MODEL=accounts/fireworks/models/llama-v3p1-8b-instruct

# --- Optional AMD / GPU / ML model overrides ---
# SAFEO_AMD_DEVICE=cuda
SAFEO_ENABLE_GPU_METRICS=true
SAFEO_TIER2_MODEL_NAME=distilbert-base-uncased
SAFEO_MULTILINGUAL_MODEL_NAME=aubmindlab/bert-base-arabertv2

# --- Visual evidence demo (Playwright screenshot base URL) ---
SAFEO_VISUAL_DEMO_BASE=http://127.0.0.1:8001

# --- Jira escalation (Logs page — create tickets from engine decisions) ---
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=AMD
